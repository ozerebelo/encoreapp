# Postgres connection. On macOS Homebrew Postgres the default superuser is your
# system username with no password.
DATABASE_URL="postgresql://USER@localhost:5432/livemusic?schema=public"

# Secret used to sign session cookies (any long random string).
AUTH_SECRET="change-me-to-a-long-random-string"

# Optional — real data importers. Without these the app uses the demo seed.
# Past catalogue + setlists: https://api.setlist.fm/docs/1.0/index.html
SETLISTFM_API_KEY=""
# Upcoming concerts: https://artists.bandsintown.com/support/api-installation
BANDSINTOWN_APP_ID=""
